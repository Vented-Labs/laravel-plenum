{
    "name": "vented/laravel-plenum",
    "description": "Application-layer routing for Laravel. Pin requests to specific backing connections (database, Redis, custom) using consistent hashing, pluggable routing strategies, active health checks, and automatic failover.",
    "keywords": [
        "laravel",
        "consistent-hashing",
        "routing",
        "ha",
        "multi-master",
        "sharding",
        "redis",
        "postgres"
    ],
    "license": "MIT",
    "type": "library",
    "homepage": "https://github.com/Vented-Labs/laravel-plenum",
    "support": {
        "issues": "https://github.com/Vented-Labs/laravel-plenum/issues",
        "source": "https://github.com/Vented-Labs/laravel-plenum"
    },
    "authors": [
        {
            "name": "Mason Curry",
            "email": "mason.curry1@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.5",
        "ext-hash": "*",
        "esi/consistent-hash": "^2.0",
        "illuminate/contracts": "^13.0",
        "illuminate/database": "^13.0",
        "illuminate/redis": "^13.0",
        "illuminate/support": "^13.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.88",
        "larastan/larastan": "^3.0",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "Vented\\Plenum\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vented\\Plenum\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage --min=100",
        "format": "vendor/bin/php-cs-fixer fix"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Vented\\Plenum\\PlenumServiceProvider"
            ],
            "aliases": {
                "Plenum": "Vented\\Plenum\\Facades\\Plenum"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    }
}
